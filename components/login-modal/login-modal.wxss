/* components/login-modal/login-modal.wxss */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.login-modal {
  width: 600rpx;
  background-color: #fff;
  border-radius: 30rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  padding: 50rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.icon-emoji {
  font-size: 60rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.login-benefits {
  width: 100%;
  margin-bottom: 50rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
}

.benefit-icon {
  color: #667eea;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 15rpx;
  width: 30rpx;
}

.benefit-text {
  font-size: 28rpx;
  color: #666;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.login-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.btn-text {
  font-size: 32rpx;
}

.login-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}

.tips-text {
  font-size: 22rpx;
  color: #999;
}

.tips-link {
  font-size: 22rpx;
  color: #667eea;
  margin: 0 5rpx;
}

/* 第二步：完善资料表单 */
.modal-content-step2 {
  align-items: stretch;
}
.step2-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 36rpx;
  text-align: center;
}
.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  gap: 16rpx;
}
.form-row-avatar {
  align-items: center;
}
.form-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}
.form-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}
.form-auth-btn {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #667eea;
  background: #f0f0ff;
  border-radius: 24rpx;
  border: none;
  line-height: 1.2;
}
.form-auth-btn::after {
  border: none;
}

.avatar-wrapper {
  flex-shrink: 0;
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  min-height: 120rpx;
  max-width: 120rpx;
  max-height: 120rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  overflow: hidden;
  background: #f5f5f5;
  border: none;
  display: block;
  box-sizing: border-box;
  line-height: 0;
}

.avatar-wrapper::after {
  border: none;
}
.avatar-slot {
  flex: 1;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f5f5f5;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  min-height: 120rpx;
  border-radius: 50%;
  display: block;
  object-fit: cover;
}
.avatar-placeholder {
  font-size: 24rpx;
  color: #999;
}
.save-profile-btn {
  margin-top: 40rpx;
}
