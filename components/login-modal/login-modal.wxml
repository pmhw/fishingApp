<!--components/login-modal/login-modal.wxml-->
<view class="login-modal-mask" wx:if="{{show}}" bindtap="onMaskTap">
  <view class="login-modal" catchtap="true">
    <view class="modal-header">
      <text class="modal-title">{{step === 1 ? '欢迎使用' : '完善资料'}}</text>
      <text class="modal-close" bindtap="onClose">✕</text>
    </view>

    <!-- 第一步：微信登录 -->
    <view class="modal-content" wx:if="{{step === 1}}">
      <view class="login-icon">
        <text class="icon-emoji">🎣</text>
      </view>
      <text class="login-title">垂钓会员中心</text>
      <text class="login-desc">登录后享受更多专属权益</text>
      <view class="login-benefits">
        <view class="benefit-item">
          <text class="benefit-icon">✓</text>
          <text class="benefit-text">会员专享折扣</text>
        </view>
        <view class="benefit-item">
          <text class="benefit-icon">✓</text>
          <text class="benefit-text">积分奖励</text>
        </view>
        <view class="benefit-item">
          <text class="benefit-icon">✓</text>
          <text class="benefit-text">优先预约钓场</text>
        </view>
      </view>
      <button class="login-btn" bindtap="onTapLogin">
        <text class="btn-icon">🔐</text>
        <text class="btn-text">微信一键登录</text>
      </button>
      <view class="login-tips">
        <text class="tips-text">登录即表示同意</text>
        <text class="tips-link" bindtap="onAgreementTap">《用户协议》</text>
        <text class="tips-text">和</text>
        <text class="tips-link" bindtap="onPrivacyTap">《隐私政策》</text>
      </view>
    </view>

    <!-- 第二步：首次登录需授权并填写昵称、头像到表单，再保存 -->
    <view class="modal-content modal-content-step2" wx:if="{{step === 2}}">
      <text class="step2-desc">请设置头像与昵称后保存到服务器</text>
      <view class="form-row form-row-avatar">
        <text class="form-label">头像</text>
        <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{formAvatarDisplay || defaultAvatarUrl}}" mode="aspectFill" />
        </button>
      </view>
      <view class="form-row">
        <text class="form-label">昵称</text>
        <input
          type="nickname"
          class="form-input weui-input"
          placeholder="请输入昵称"
          value="{{formNickname}}"
          bindinput="onFormNicknameInput"
        />
      </view>
      <button class="login-btn save-profile-btn" bindtap="onSaveProfile">保存并完成登录</button>
    </view>
  </view>
</view>
