<!-- 参考 miniprogram-1：独立登录页，第一步仅微信 code 登录 -->
<view class="page login">
  <view class="login__title">欢迎登录</view>
  <view class="login__subtitle">垂钓会员中心</view>
  <view class="login__content">
    <view class="login__tips">登录后享受会员专享折扣、积分奖励、优先预约钓场</view>
    <view class="login__button">
      <button class="btn-primary" bindtap="onLogin">微信一键登录</button>
    </view>
    <view class="login__agree">
      <text class="agree-text">登录即表示同意</text>
      <text class="agree-link" bindtap="onAgreement">《用户协议》</text>
      <text class="agree-text">和</text>
      <text class="agree-link" bindtap="onPrivacy">《隐私政策》</text>
    </view>
  </view>
</view>
