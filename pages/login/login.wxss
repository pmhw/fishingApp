/* 参考 miniprogram-1 登录页样式 */
.page.login {
  min-height: 100vh;
  background: #fff;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.login__title {
  color: rgba(0, 0, 0, 0.9);
  font-size: 56rpx;
  font-weight: 600;
  line-height: 72rpx;
  padding: 16rpx 0 8rpx;
}

.login__subtitle {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-bottom: 64rpx;
}

.login__content {
  margin-top: 32rpx;
}

.login__tips {
  color: rgba(0, 0, 0, 0.4);
  font-size: 24rpx;
  line-height: 40rpx;
  margin-bottom: 48rpx;
}

.login__button {
  margin: 0 0 32rpx;
}

.login__button .btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 44rpx;
}

.login__button .btn-primary::after {
  border: none;
}

.login__agree {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
}

.login__agree .agree-link {
  color: #667eea;
  margin: 0 4rpx;
}
