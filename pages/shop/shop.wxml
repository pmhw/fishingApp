<!-- pages/shop/shop.wxml -->
<view class="shop-container">
  <!-- 左侧分类 -->
  <view class="category-panel">
    <scroll-view 
      scroll-y="true" 
      class="category-scroll"
    >
      <view 
        class="category-item {{currentCategoryId === item.id ? 'active' : ''}}" 
        wx:for="{{categoryList}}" 
        wx:key="id"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
      >
        <text class="category-name">{{item.name}}</text>
        <view class="category-indicator" wx:if="{{currentCategoryId === item.id}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 右侧商品列表 -->
  <view class="product-panel">
    <scroll-view 
      scroll-y="true" 
      class="product-scroll"
    >
      <view class="product-grid">
        <view 
          class="product-card" 
          wx:for="{{displayProducts}}" 
          wx:key="id"
          bindtap="onProductTap"
          data-product="{{item}}"
        >
          <view class="product-image">
            <text class="image-placeholder">🛒</text>
          </view>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-desc">{{item.desc}}</text>
            <view class="product-bottom">
              <text class="product-price">¥{{item.price}}</text>
              <text class="product-tag">{{item.tag}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 右下角悬浮购物车 -->
  <view class="cart-float" bindtap="onOpenCart">
    <text class="cart-float-icon">🛒</text>
    <view class="cart-float-badge" wx:if="{{cartCount > 0}}">{{cartCount > 99 ? '99+' : cartCount}}</view>
  </view>

  <!-- 购物车抽屉 -->
  <view class="cart-mask" wx:if="{{showCartDrawer}}" bindtap="onCloseCart"></view>
  <view class="cart-drawer {{showCartDrawer ? 'cart-drawer--show' : ''}}">
    <view class="cart-drawer-header">
      <text class="cart-drawer-title">购物车</text>
      <text class="cart-drawer-close" bindtap="onCloseCart">关闭</text>
    </view>
    <scroll-view scroll-y class="cart-drawer-body" wx:if="{{cartList.length > 0}}">
      <view class="cart-item" wx:for="{{cartList}}" wx:key="_key">
        <view class="cart-item-image"><text class="image-placeholder">🛒</text></view>
        <view class="cart-item-info">
          <text class="cart-item-name">{{item.name}}</text>
          <text class="cart-item-spec" wx:if="{{item.spec}}">规格：{{item.spec}}</text>
          <text class="cart-item-price">¥{{item.price}} x{{item.quantity || 1}}</text>
        </view>
        <view class="cart-item-del" data-index="{{index}}" bindtap="onRemoveCartItem">删除</view>
      </view>
    </scroll-view>
    <view class="cart-drawer-empty" wx:else>
      <text>购物车是空的</text>
    </view>
  </view>
</view>
