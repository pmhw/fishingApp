/* pages/records/records.wxss */
/* 覆盖 app 全局 .container，避免 flex/居中/大 padding 影响本页和登录区 */
.container {
  display: block;
  align-items: stretch;
  justify-content: flex-start;
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 未登录：请先登录（独立块，不受页面其它样式影响） */
.login-required {
  width: 100%;
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

.login-required .login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 600rpx;
}

.login-required .prompt-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  line-height: 1;
}

.login-required .prompt-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
}

.login-required .prompt-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
  text-align: center;
}

.login-required .prompt-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-required .prompt-btn::after {
  border: none;
}

/* 统计信息 */
.stats-section {
  display: flex;
  background-color: #fff;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 记录区域 */
.records-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

/* 记录列表 */
.records-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-image {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.image-placeholder {
  font-size: 60rpx;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.record-date {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.record-weather {
  font-size: 24rpx;
  color: #999;
  padding: 5rpx 15rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
}

.record-spot {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.record-details {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.detail-item {
  font-size: 24rpx;
  color: #999;
  padding: 5rpx 15rpx;
  background-color: #f9f9f9;
  border-radius: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}
