/* pages/search/search.wxss */
page {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
}

.search-page {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

/* 顶部搜索栏 */
.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-top: 16rpx;
  background-color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 12rpx 20rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.search-cancel {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #666;
}

/* 最近搜索 */
.history-section {
  padding: 20rpx 20rpx 10rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.history-clear-all {
  font-size: 24rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
}

.history-chip {
  padding: 8rpx 18rpx;
  border-radius: 40rpx;
  background-color: #f0f0f0;
}

.chip-text {
  font-size: 24rpx;
  color: #333;
}

.history-delete {
  font-size: 20rpx;
  color: #bbb;
  margin-left: 4rpx;
}

/* 搜索结果 */
.result-section {
  margin-top: 10rpx;
  padding: 10rpx 20rpx 120rpx;
}

.result-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.result-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.result-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-main {
  flex: 1;
  margin-right: 12rpx;
}

.result-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.result-desc {
  font-size: 24rpx;
  color: #999;
}

.result-type {
  font-size: 22rpx;
  color: #667eea;
  align-self: center;
}

/* 空状态 */
.empty-section {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.3;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

