/* 参考 miniprogram-1 loginCode 第二步页样式 */
.page.login-profile {
  min-height: 100vh;
  background: #fff;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.login-profile__title {
  color: rgba(0, 0, 0, 0.9);
  font-size: 56rpx;
  font-weight: 600;
  line-height: 72rpx;
  padding: 16rpx 0 16rpx;
}

.login-profile__tips {
  margin: 0 0 48rpx;
  color: rgba(0, 0, 0, 0.4);
  font-size: 24rpx;
  line-height: 40rpx;
}

.login-profile__form {
  margin-bottom: 56rpx;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  gap: 16rpx;
}

.form-row-avatar {
  align-items: center;
}

.form-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.avatar-wrapper {
  flex-shrink: 0;
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  min-height: 120rpx;
  max-width: 120rpx;
  max-height: 120rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  overflow: hidden;
  background: #f5f5f5;
  border: none;
  display: block;
  box-sizing: border-box;
  line-height: 0;
}

.avatar-wrapper::after {
  border: none;
}

.form-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.form-btn {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #667eea;
  background: #f0f0ff;
  border-radius: 24rpx;
  border: none;
  line-height: 1.2;
}

.form-btn::after {
  border: none;
}

.avatar-slot {
  flex: 1;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f5f5f5;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  min-height: 120rpx;
  border-radius: 50%;
  display: block;
  object-fit: cover;
}

.avatar-placeholder {
  font-size: 24rpx;
  color: #999;
}

.login-profile__button .btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 44rpx;
}

.login-profile__button .btn-primary[disabled] {
  opacity: 0.5;
}

.login-profile__button .btn-primary::after {
  border: none;
}
